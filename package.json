{
  "name": "agent-ready-drupal-build-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agent instructions and packet verification for source-site rebuilds and brief-driven Drupal CMS builds.",
  "license": "MIT",
  "homepage": "https://github.com/scottfalconer/agent-ready-drupal-build-kit#readme",
  "bugs": {
    "url": "https://github.com/scottfalconer/agent-ready-drupal-build-kit/issues"
  },
  "keywords": [
    "drupal",
    "drupal-cms",
    "agent-skills",
    "ai-agent",
    "site-rebuild",
    "ddev"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scottfalconer/agent-ready-drupal-build-kit.git"
  },
  "scripts": {
    "prepack": "node scripts/sync-skill-package.mjs --check --quiet",
    "test": "node --test --test-concurrency=2 tests/*.test.mjs",
    "reconcile": "node bin/reconcile.mjs",
    "doctor": "node bin/doctor.mjs",
    "verify": "node bin/verify.mjs",
    "verify-packet": "node bin/verify-packet.mjs",
    "review-handoff": "node bin/review-handoff.mjs",
    "verify-assembly": "node bin/verify-assembly.mjs",
    "verify-reproduction": "node bin/verify-reproduction.mjs",
    "lifecycle": "node bin/lifecycle.mjs"
  },
  "bin": {
    "agent-ready-drupal-reconcile": "bin/reconcile.mjs",
    "agent-ready-drupal-doctor": "bin/doctor.mjs",
    "agent-ready-drupal-verify": "bin/verify.mjs",
    "agent-ready-drupal-verify-packet": "bin/verify-packet.mjs",
    "agent-ready-drupal-review-handoff": "bin/review-handoff.mjs",
    "agent-ready-drupal-verify-assembly": "bin/verify-assembly.mjs",
    "agent-ready-drupal-verify-reproduction": "bin/verify-reproduction.mjs",
    "agent-ready-drupal-lifecycle": "bin/lifecycle.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
